# ──────────────────────────────────────────────────────────────────────────
# ServiceLead AI — environment variables
# Copy this file to `.env.local` and fill in the values you have.
# The app is designed to run with ONLY the Supabase keys set. Everything else
# (Twilio, Stripe, Resend, real AI) is optional and degrades gracefully.
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (required) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider -------------------------------------------------------------
# One of: mock | openai | anthropic. Defaults to `mock` when unset.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Twilio (optional) -------------------------------------------------------
# Leave blank to run in simulation mode (see /app/simulator).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
# Set to "false" to skip webhook signature validation in local dev.
TWILIO_VALIDATE_SIGNATURE=true

# --- Resend owner emails (optional) -----------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=ServiceLead AI <leads@example.com>

# --- Stripe billing (optional) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_GROWTH=

# --- Observability (optional) -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
