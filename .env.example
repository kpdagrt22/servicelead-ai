# ──────────────────────────────────────────────────────────────────────────
# ServiceLead AI — environment variables
# Copy this file to `.env.local` and fill in the values you have.
# The app is designed to run with ONLY the Supabase keys set. Everything else
# (Twilio, Stripe, Resend, real AI) is optional and degrades gracefully.
# Verify your setup any time with: npm run verify:env
# NEVER commit real values — .env.local is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (required) -----------------------------------------------------
# Public (sent to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the client. Used by webhooks & public intake.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider -------------------------------------------------------------
# One of: mock | openai | anthropic. Defaults to `mock` (no key needed).
AI_PROVIDER=mock
# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Network budget for real-provider calls (a hung LLM must not block webhooks).
AI_TIMEOUT_MS=12000
AI_MAX_RETRIES=1

# --- Twilio (optional) -------------------------------------------------------
# Leave blank to run in simulation mode (see /app/simulator).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
# Set to "false" to skip webhook signature validation OUTSIDE production only.
TWILIO_VALIDATE_SIGNATURE=true

# --- Owner email notifications (optional, Resend) ---------------------------
RESEND_API_KEY=
# Canonical sender address (falls back to RESEND_FROM_EMAIL for back-compat).
FROM_EMAIL=ServiceLead AI <leads@example.com>

# --- Stripe billing (optional) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs are not secret; the public names let the pricing UI read them.
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=

# --- Observability (optional) -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated emails allowed into the internal admin/debug page (/app/admin).
ADMIN_EMAILS=
